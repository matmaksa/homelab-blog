    <link rel="stylesheet" href="/v2/css/menu.css?v=1.20260325" />
    <link rel="stylesheet" href="/Styles/ProductConfigurationDetail.css?v=1.20260325" />
    <link rel="stylesheet" href="/frameworkFiles/FixedTable/fixed-table.css?v=1.20260325" />
